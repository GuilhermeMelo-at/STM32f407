  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  /* USER CODE BEGIN 2 */
  Utility_Init();
  USART1_Init();


  GPIO_Clock_Enable(GPIOA);
  GPIO_Clock_Enable(GPIOE);

  //Solto k1 vai para 1. Pressionado, vai para 0. PULL UP
  //Solto k0 vai para 1. Pressionado, vai para 0. PULL UP


  GPIO_Pin_Mode(GPIOE, PIN_3, INPUT); //Botão K1
  GPIO_Resistor_Enable(GPIOE, PIN_3, PULL_UP); //Resistor do K1

  GPIO_Pin_Mode(GPIOE, PIN_4, INPUT); //Botão K0
  GPIO_Resistor_Enable(GPIOE, PIN_4, PULL_UP); //Resistor do K0


  GPIO_Pin_Mode(GPIOA, PIN_7, OUTPUT); //Led D3
  GPIO_Pin_Mode(GPIOA, PIN_6, OUTPUT); //Led D2

  GPIO_Write_Pin(GPIOA, PIN_7,HIGH);//Estado inicial dos leds desligado
  GPIO_Write_Pin(GPIOA, PIN_6,HIGH);

  GPIO_Pin_Mode(GPIOA,PIN_0,ANALOG); //PA0 como entrada analógica

  //Configurações de interrupções externas

  EXTI_Config(EXTI3, GPIOE, FALLING_EDGE); //Declara interrupção e borda de descida
  EXTI_Config(EXTI4, GPIOE, FALLING_EDGE);

  NVIC_EnableIRQ(EXTI3_IRQn); //Configura NVIC
  NVIC_EnableIRQ(EXTI4_IRQn);

  NVIC_SetPriority(EXTI3_IRQn, 0); //Configura prioridade
  NVIC_SetPriority(EXTI4_IRQn, 1);


  //Configurações de ADC para potenciômetro
  ADC_Init(ADC1, SINGLE_CHANNEL, DAC_RES_12BITS); //Um canal com resolução de 12bits
  ADC_SingleChannel(ADC1,ADC_IN0);

  //Configurações de ADC para sensor de temperatura
  RCC-> APB2ENR |= RCC_APB2ENR_ADC1EN;// Liga o clock

  ADC->CCR |= 0b01 << 16;                  // Configura o prescaler do ADC para /4
  ADC1->SQR1 &= ~(0xF << 20);             // Configura a sequência para realizar apenas 1 conversão
  ADC1->SQR3 |= 16;                       // Seleciona o Canal 16 para ser o primeiro da sequência de conversão
  ADC1->SMPR1 |= (7 << 18);               // Define o tempo de amostragem do Canal 16 para 480 ciclos
  ADC->CCR |= ADC_CCR_TSVREFE;            // Liga o sensor de temperatura interno e o VREFINT
  ADC1->CR2 |= ADC_CR2_ADON;              // Liga o ADC1

  uint32_t *p = (uint32_t *) 0x1FFF7A20;  // Ponteiro para os dados de calibração de fábrica
  uint32_t Word = *p;                     // Lê os 32 bits do endereço de calibração
  uint16_t TS_CAL1 = (Word & 0x0000FFFF); // Extrai os 16 bits menos significativos (TS_CAL1)
  uint16_t TS_CAL2 = (Word & 0xFFFF0000) >> 16; // Extrai os 16 bits mais significativos (TS_CAL2)

  // Inicializa DAC canal 2 (PA5)
  DAC_Init(DAC_CHANNEL2);

  const uint16_t samples [200] = {
		  2048,2080,2112,2144,2176,2208,2240,2272,2304,2335,
		  2367,2398,2429,2460,2491,2521,2551,2581,2610,2639,
		  2667,2695,2722,2749,2775,2801,2826,2850,2874,2897,
		  2919,2941,2961,2981,3000,3019,3036,3053,3068,3083,
		  3097,3110,3121,3132,3142,3150,3158,3164,3169,3173,
		  3176,3178,3178,3178,3176,3173,3169,3164,3158,3150,
		  3142,3132,3121,3110,3097,3083,3068,3053,3036,3019,
		  3000,2981,2961,2941,2919,2897,2874,2850,2826,2801,
		  2775,2749,2722,2695,2667,2639,2610,2581,2551,2521,
		  2491,2460,2429,2398,2367,2335,2304,2272,2240,2208,
		  2176,2144,2112,2080,2048,2015,1983,1951,1919,1887,
		  1855,1823,1791,1760,1729,1698,1667,1637,1607,1577,
		  1548,1519,1491,1463,1436,1409,1383,1357,1332,1308,
		  1284,1261,1239,1217,1197,1177,1158,1139,1122,1105,
		  1090,1075,1061,1048,1037,1026,1016,1008,1000,994,
		  989,985,982,980,978,978,978,980,982,985,
		  989,994,1000,1008,1016,1026,1037,1048,1061,1075,
		  1090,1105,1122,1139,1158,1177,1197,1217,1239,1261,
		  1284,1308,1332,1357,1383,1409,1436,1463,1491,1519,
		  1548,1577,1607,1637,1667,1698,1729,1760,1791,1823,
		  1855,1887,1919,1951,1983,2015
  };


  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */



  while (1)
  {
	  	 for(uint8_t i = 0; i < 200; i++){
	  		 DAC_SetValue(DAC_CHANNEL2, samples[i], DAC_RES_12BITS);
	  		 Delay_us(200); // Periodo = 20 ms; f= 1/200amostras * 200us = 25Hz; vpp = 1.773 V; vm = 1.675 V;
	  	 }



  }
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
}
